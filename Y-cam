<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>GR Cam</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --black: #0e0e0e;
    --darkgray: #1a1a1a;
    --midgray: #2c2c2c;
    --silver: #8a8a8a;
    --cream: #e8e0d0;
    --accent: #c8a96e;
  }

  body {
    background: var(--black);
    color: var(--cream);
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    user-select: none;
  }

  /* ── Header ── */
  #header {
    width: 100%;
    max-width: 420px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 20px 10px;
  }
  #logo {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--cream);
  }
  #mode-badge {
    font-size: 10px;
    letter-spacing: 0.15em;
    color: var(--silver);
    border: 1px solid var(--midgray);
    padding: 3px 8px;
    border-radius: 2px;
  }

  /* ── Viewfinder ── */
  #viewfinder-wrap {
    position: relative;
    width: 100%;
    max-width: 420px;
    flex: 1;
    overflow: hidden;
    background: #000;
  }

  #video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Film grain overlay */
  #grain {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='1'/%3E%3C/svg%3E");
    background-size: 180px 180px;
    mix-blend-mode: overlay;
  }

  /* Vignette */
  #vignette {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s;
    background: radial-gradient(ellipse at center, transparent 45%, rgba(0,0,0,0.72) 100%);
  }

  /* Color grade canvas */
  #canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: none;
  }

  /* Corner brackets */
  .corner {
    position: absolute;
    width: 18px;
    height: 18px;
    opacity: 0.5;
  }
  .corner.tl { top: 12px; left: 12px; border-top: 1px solid var(--cream); border-left: 1px solid var(--cream); }
  .corner.tr { top: 12px; right: 12px; border-top: 1px solid var(--cream); border-right: 1px solid var(--cream); }
  .corner.bl { bottom: 12px; left: 12px; border-bottom: 1px solid var(--cream); border-left: 1px solid var(--cream); }
  .corner.br { bottom: 12px; right: 12px; border-bottom: 1px solid var(--cream); border-right: 1px solid var(--cream); }

  /* Focus indicator */
  #focus-ring {
    position: absolute;
    width: 60px;
    height: 60px;
    border: 1px solid var(--accent);
    transform: translate(-50%, -50%);
    pointer-events: none;
    display: none;
    animation: focusPulse 0.3s ease-out;
  }
  @keyframes focusPulse {
    from { width: 90px; height: 90px; opacity: 0; }
    to { width: 60px; height: 60px; opacity: 1; }
  }

  /* Shutter flash */
  #flash {
    position: absolute;
    inset: 0;
    background: white;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.05s;
  }

  /* ── Preset bar ── */
  #preset-bar {
    width: 100%;
    max-width: 420px;
    display: flex;
    gap: 0;
    background: var(--darkgray);
    border-top: 1px solid #2a2a2a;
    border-bottom: 1px solid #2a2a2a;
  }
  .preset-btn {
    flex: 1;
    padding: 10px 4px;
    background: none;
    border: none;
    color: var(--silver);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    transition: color 0.2s, background 0.2s;
    border-right: 1px solid #2a2a2a;
  }
  .preset-btn:last-child { border-right: none; }
  .preset-btn.active {
    color: var(--accent);
    background: rgba(200,169,110,0.08);
  }
  .preset-btn:active { background: rgba(255,255,255,0.05); }

  /* ── Controls ── */
  #controls {
    width: 100%;
    max-width: 420px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 30px 24px;
    background: var(--black);
  }

  /* Flip button */
  #flip-btn {
    width: 44px; height: 44px;
    background: var(--midgray);
    border: none;
    border-radius: 50%;
    color: var(--cream);
    font-size: 18px;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.2s;
  }
  #flip-btn:active { background: #3a3a3a; }

  /* Shutter */
  #shutter-btn {
    width: 72px; height: 72px;
    background: var(--cream);
    border: none;
    border-radius: 50%;
    cursor: pointer;
    position: relative;
    transition: transform 0.1s;
    box-shadow: 0 0 0 6px var(--midgray), 0 0 0 7px #3a3a3a;
  }
  #shutter-btn::after {
    content: '';
    position: absolute;
    inset: 6px;
    background: white;
    border-radius: 50%;
  }
  #shutter-btn:active { transform: scale(0.93); }

  /* Save button */
  #save-btn {
    width: 44px; height: 44px;
    background: var(--midgray);
    border: none;
    border-radius: 50%;
    color: var(--cream);
    font-size: 16px;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.2s;
  }
  #save-btn:active { background: #3a3a3a; }

  /* ── Permission screen ── */
  #permission-screen {
    position: absolute;
    inset: 0;
    background: var(--black);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 20px;
    z-index: 10;
  }
  #permission-screen p {
    color: var(--silver);
    font-size: 13px;
    letter-spacing: 0.05em;
    text-align: center;
    max-width: 240px;
    line-height: 1.7;
  }
  #start-btn {
    background: none;
    border: 1px solid var(--accent);
    color: var(--accent);
    padding: 12px 32px;
    font-size: 12px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    cursor: pointer;
    border-radius: 2px;
    transition: background 0.2s;
  }
  #start-btn:hover { background: rgba(200,169,110,0.1); }

  /* ── Thumbnail preview ── */
  #thumb-wrap {
    position: absolute;
    bottom: 10px;
    left: 12px;
    width: 52px;
    height: 52px;
    border: 1px solid var(--silver);
    border-radius: 3px;
    overflow: hidden;
    opacity: 0;
    transition: opacity 0.3s;
    cursor: pointer;
  }
  #thumb-wrap img {
    width: 100%; height: 100%; object-fit: cover;
  }

  /* ── Film counter ── */
  #film-counter {
    position: absolute;
    top: 12px;
    right: 14px;
    font-size: 11px;
    letter-letters: 0.1em;
    color: var(--accent);
    font-variant-numeric: tabular-nums;
  }

  /* ── Toast ── */
  #toast {
    position: fixed;
    bottom: 120px;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(0,0,0,0.8);
    color: var(--cream);
    font-size: 12px;
    letter-spacing: 0.1em;
    padding: 8px 20px;
    border-radius: 2px;
    border: 1px solid var(--midgray);
    opacity: 0;
    transition: opacity 0.3s;
    pointer-events: none;
    white-space: nowrap;
    z-index: 20;
  }
  #toast.show { opacity: 1; }
</style>
</head>
<body>

<div id="header">
  <span id="logo">GR Cam</span>
  <span id="mode-badge">POSITIVE</span>
</div>

<div id="viewfinder-wrap">
  <video id="video" autoplay playsinline muted></video>
  <canvas id="canvas"></canvas>
  <div id="grain"></div>
  <div id="vignette"></div>
  <div class="corner tl"></div>
  <div class="corner tr"></div>
  <div class="corner bl"></div>
  <div class="corner br"></div>
  <div id="focus-ring"></div>
  <div id="flash"></div>
  <div id="film-counter">000</div>
  <div id="thumb-wrap"><img id="thumb-img" src="" alt=""></div>

  <div id="permission-screen">
    <span style="font-size:13px;letter-spacing:0.25em;color:var(--cream)">GR CAM</span>
    <p>カメラへのアクセスを許可してください</p>
    <button id="start-btn">カメラを起動</button>
  </div>
</div>

<div id="preset-bar">
  <button class="preset-btn active" data-preset="gr">GR</button>
  <button class="preset-btn" data-preset="mono">MONO</button>
  <button class="preset-btn" data-preset="pos">VELVIA</button>
  <button class="preset-btn" data-preset="fade">FADE</button>
  <button class="preset-btn" data-preset="warm">WARM</button>
</div>

<div id="controls">
  <button id="flip-btn" title="カメラ切替">⇄</button>
  <button id="shutter-btn" title="撮影"></button>
  <button id="save-btn" title="保存">↓</button>
</div>

<div id="toast"></div>

<script>
const video = document.getElementById('video');
const canvas = document.getElementById('canvas');
const grain = document.getElementById('grain');
const vignette = document.getElementById('vignette');
const focusRing = document.getElementById('focus-ring');
const flashEl = document.getElementById('flash');
const filmCounter = document.getElementById('film-counter');
const thumbWrap = document.getElementById('thumb-wrap');
const thumbImg = document.getElementById('thumb-img');
const modeBadge = document.getElementById('mode-badge');
const toast = document.getElementById('toast');
const permissionScreen = document.getElementById('permission-screen');

let facingMode = 'environment';
let shotCount = 0;
let currentPreset = 'gr';
let lastDataUrl = null;
let stream = null;

// ── Presets ──
const presets = {
  gr: {
    label: 'POSITIVE',
    contrast: 1.18,
    brightness: 0.96,
    saturate: 0.82,
    sepia: 0.06,
    grain: 0.28,
    vignette: 0.6,
    hue: 0,
    // CSS filter for live preview
    filter: 'contrast(1.18) brightness(0.96) saturate(0.82) sepia(0.06)',
  },
  mono: {
    label: 'MONO',
    contrast: 1.22,
    brightness: 0.93,
    saturate: 0,
    sepia: 0,
    grain: 0.45,
    vignette: 0.75,
    hue: 0,
    filter: 'contrast(1.22) brightness(0.93) grayscale(1)',
  },
  pos: {
    label: 'VELVIA',
    contrast: 1.28,
    brightness: 1.0,
    saturate: 1.4,
    sepia: 0.03,
    grain: 0.18,
    vignette: 0.5,
    hue: 5,
    filter: 'contrast(1.28) brightness(1.0) saturate(1.4) hue-rotate(5deg)',
  },
  fade: {
    label: 'FADE',
    contrast: 0.88,
    brightness: 1.08,
    saturate: 0.65,
    sepia: 0.12,
    grain: 0.38,
    vignette: 0.4,
    hue: -5,
    filter: 'contrast(0.88) brightness(1.08) saturate(0.65) sepia(0.12)',
  },
  warm: {
    label: 'WARM',
    contrast: 1.1,
    brightness: 1.02,
    saturate: 0.9,
    sepia: 0.18,
    grain: 0.22,
    vignette: 0.55,
    hue: 10,
    filter: 'contrast(1.1) brightness(1.02) saturate(0.9) sepia(0.18) hue-rotate(10deg)',
  },
};

function applyPreset(name) {
  const p = presets[name];
  video.style.filter = p.filter;
  grain.style.opacity = p.grain;
  vignette.style.opacity = p.vignette;
  modeBadge.textContent = p.label;
}

// ── Start camera ──
async function startCamera() {
  try {
    if (stream) stream.getTracks().forEach(t => t.stop());
    stream = await navigator.mediaDevices.getUserMedia({
      video: { facingMode, width: { ideal: 1920 }, height: { ideal: 1080 } },
      audio: false,
    });
    video.srcObject = stream;
    permissionScreen.style.display = 'none';
    applyPreset(currentPreset);
  } catch (e) {
    showToast('カメラにアクセスできません');
  }
}

document.getElementById('start-btn').addEventListener('click', startCamera);

// ── Preset buttons ──
document.querySelectorAll('.preset-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.preset-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    currentPreset = btn.dataset.preset;
    applyPreset(currentPreset);
  });
});

// ── Focus tap ──
document.getElementById('viewfinder-wrap').addEventListener('click', (e) => {
  if (e.target === document.getElementById('start-btn') || e.target.closest('#permission-screen')) return;
  const rect = e.currentTarget.getBoundingClientRect();
  const x = e.clientX - rect.left;
  const y = e.clientY - rect.top;
  focusRing.style.left = x + 'px';
  focusRing.style.top = y + 'px';
  focusRing.style.display = 'block';
  focusRing.style.animation = 'none';
  void focusRing.offsetWidth;
  focusRing.style.animation = 'focusPulse 0.3s ease-out';
  setTimeout(() => focusRing.style.display = 'none', 1200);
});

// ── Shutter ──
document.getElementById('shutter-btn').addEventListener('click', shoot);

function shoot() {
  if (!stream) { showToast('カメラを起動してください'); return; }

  // Flash
  flashEl.style.opacity = 0.7;
  setTimeout(() => flashEl.style.opacity = 0, 100);

  // Capture with filter applied via canvas
  const w = video.videoWidth || 1280;
  const h = video.videoHeight || 720;
  canvas.width = w;
  canvas.height = h;
  const ctx = canvas.getContext('2d');
  const p = presets[currentPreset];

  // Draw video frame
  ctx.filter = p.filter;
  ctx.drawImage(video, 0, 0, w, h);
  ctx.filter = 'none';

  // Vignette
  if (p.vignette > 0) {
    const vg = ctx.createRadialGradient(w/2, h/2, h*0.3, w/2, h/2, h*0.85);
    vg.addColorStop(0, 'rgba(0,0,0,0)');
    vg.addColorStop(1, `rgba(0,0,0,${p.vignette * 0.85})`);
    ctx.fillStyle = vg;
    ctx.fillRect(0, 0, w, h);
  }

  // Grain
  if (p.grain > 0) {
    const imgData = ctx.getImageData(0, 0, w, h);
    const d = imgData.data;
    const intensity = p.grain * 60;
    for (let i = 0; i < d.length; i += 4) {
      const n = (Math.random() - 0.5) * intensity;
      d[i] = Math.min(255, Math.max(0, d[i] + n));
      d[i+1] = Math.min(255, Math.max(0, d[i+1] + n));
      d[i+2] = Math.min(255, Math.max(0, d[i+2] + n));
    }
    ctx.putImageData(imgData, 0, 0);
  }

  lastDataUrl = canvas.toDataURL('image/jpeg', 0.92);

  // Thumbnail
  thumbImg.src = lastDataUrl;
  thumbWrap.style.opacity = 1;

  // Counter
  shotCount++;
  filmCounter.textContent = String(shotCount).padStart(3, '0');

  showToast('撮影しました');
}

// ── Save ──
document.getElementById('save-btn').addEventListener('click', () => {
  if (!lastDataUrl) { showToast('先に撮影してください'); return; }
  const a = document.createElement('a');
  a.href = lastDataUrl;
  a.download = `grcam_${Date.now()}.jpg`;
  a.click();
  showToast('保存しました');
});

// ── Flip camera ──
document.getElementById('flip-btn').addEventListener('click', () => {
  facingMode = facingMode === 'environment' ? 'user' : 'environment';
  startCamera();
});

// ── Toast ──
let toastTimer;
function showToast(msg) {
  toast.textContent = msg;
  toast.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => toast.classList.remove('show'), 1800);
}

// ── Thumbnail click: fullscreen preview ──
thumbWrap.addEventListener('click', () => {
  if (!lastDataUrl) return;
  const win = window.open();
  win.document.write(`<style>body{margin:0;background:#000;display:flex;align-items:center;justify-content:center;min-height:100vh}img{max-width:100%;max-height:100vh;object-fit:contain}</style><img src="${lastDataUrl}">`);
});
</script>
</body>
</html>
